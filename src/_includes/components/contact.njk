<div class="contact-section">
  <div class="postcard-wrapper thick-stroke">
    <div class="postcard-left">
      <h2>LET'S TALK!</h2>
      <p class="handwritten">Hey Pratik! I've got a cool project for you. Let's build something epic together!</p>
      
      <div class="stamp-box">
        <div class="stamp thick-stroke">
          <i class="ri-gamepad-line"></i>
        </div>
      </div>
    </div>
    
    <div class="postcard-divider"></div>
    
    <div class="postcard-right">
      <div class="address-line">
        <label>TO:</label>
        <span>{{ metadata.author | upper }}</span>
      </div>
      <div class="address-line">
        <label>AT:</label>
        <div class="email-wrapper">
          <a href="mailto:{{ contact.email }}" id="email-text">{{ contact.email }}</a>
          <button class="copy-btn thick-stroke" id="copy-email" aria-label="Copy email">COPY</button>
        </div>
      </div>
      <div class="address-line">
        <label>LOC:</label>
        <span>{{ contact.current_address }}</span>
      </div>
      
      <div class="social-links">
        <a href="{{ contact.github }}" target="_blank" class="social-btn thick-stroke" title="GitHub">
          <i class="ri-github-line"></i>
        </a>
        <a href="{{ contact.linkedin }}" target="_blank" class="social-btn thick-stroke" title="LinkedIn">
          <i class="ri-linkedin-line"></i>
        </a>
      </div>
    </div>
  </div>
</div>
